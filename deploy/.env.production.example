# kcalAI-model 운영(.env) 템플릿 — Lightsail 서버에 두는 실제 .env는 이 파일을 복사해 채운다.
# ⚠️ 실제 .env는 커밋하지 않는다. 아래 값 중 GEMINI_API_KEY와 DB 비밀번호만 사람이 채우고,
#    AUTH_CODE_PEPPER·HEALTH_ENCRYPTION_KEY는 provision.sh가 난수로 생성해 넣는다.

# 운영 모드. production이면 기동 시 아래 항목을 fail-fast로 검증한다.
APP_ENV=production

# DB — Postgres 같은 인스턴스 동거. <DB_PASSWORD>를 실제 비밀번호로 교체.
DATABASE_URL=postgresql+psycopg2://kcal:<DB_PASSWORD>@localhost:5432/kcal

# 인증. 운영은 dev_code 노출 금지 → false 필수(APP_ENV=production이면 true면 기동 실패).
# ⚠️ SMS 미연동 상태에서는 false면 사용자가 인증번호를 받을 수 없다(DEPLOY.md "OTP 블로커" 참고).
AUTH_INCLUDE_DEV_CODE=false
AUTH_CODE_TTL_MINUTES=5
AUTH_SESSION_TTL_DAYS=30
# provision.sh가 난수 생성해 채운다. 기본값·플레이스홀더면 production 기동 실패.
AUTH_CODE_PEPPER=<GENERATED_BY_PROVISION>

# 민감정보(혈액형·Rh) 암호화 키. base64 32바이트. provision.sh가 생성. 분실 시 복호화 불가 — 백업 필수.
HEALTH_ENCRYPTION_KEY=<GENERATED_BY_PROVISION>

# 이미지 인식(단일 백엔드). production은 없으면 기동 실패. 콘솔에서 발급한 키를 붙여넣는다.
GEMINI_API_KEY=<PASTE_GEMINI_API_KEY>
GEMINI_MODEL=gemini-flash-latest

# CORS — 운영은 명시 목록만. 앱(웹)·프런트 도메인을 콤마로. 실기기 네이티브 앱은 CORS 무관.
CORS_ALLOW_ORIGINS=https://<YOUR_DOMAIN>

# 업로드 상한(MB)
PREDICT_MAX_UPLOAD_MB=10
