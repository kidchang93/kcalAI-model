# 로컬 배포 설정 — 이 파일을 같은 폴더에 deploy.local.env 로 복사해 값을 채운다.
# deploy.local.env 는 gitignore 된다(개인 배포 대상). secret은 넣지 않는다(키 '경로'만).
# local_deploy.sh 가 자동으로 읽는다 → 매번 export 안 해도 됨.

# 서버 SSH 접속 (Lightsail 고정 IP)
SSH_HOST=ubuntu@1.2.3.4

# 서버 접속에 쓰는 SSH 개인키 경로 (~ 사용 가능)
SSH_KEY=~/.ssh/lightsail.pem

# 서버의 앱 디렉토리 (기본값이라 보통 그대로)
REMOTE_DIR=/opt/kcalAI-model
