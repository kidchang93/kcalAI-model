# development | production. production이면 기동 시 AUTH_CODE_PEPPER·AUTH_INCLUDE_DEV_CODE를 검증한다.
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://kcal:kcal@localhost:5432/kcal
AUTH_CODE_TTL_MINUTES=5
AUTH_SESSION_TTL_DAYS=30
AUTH_CODE_PEPPER=change-this-local-secret
AUTH_INCLUDE_DEV_CODE=true
# 운영은 콤마 구분 명시 목록만 허용된다 (localhost 정규식은 development에서만 적용).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
HF_TOKEN=
