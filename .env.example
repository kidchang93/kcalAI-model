# development | production. production이면 기동 시 AUTH_CODE_PEPPER·카카오 설정을 검증한다.
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://kcal:kcal@localhost:5432/kcal
AUTH_SESSION_TTL_DAYS=30
# 세션·연동코드 해시와 OAuth state 서명에 쓰인다. 운영은 반드시 교체 (기본값이면 기동 실패).
AUTH_CODE_PEPPER=change-this-local-secret

# 카카오 로그인 — **유일한 인증 수단**이다. 없으면 아무도 로그인하지 못한다 (production 기동 실패).
# REST API 키는 인가 URL에 실려 나가는 공개값이지만, CLIENT_SECRET·ADMIN_KEY는 진짜 비밀값이다.
# 콘솔: [앱] > [플랫폼 키] > [REST API 키]
KAKAO_REST_API_KEY=
# 콘솔: [앱] > [플랫폼 키] > [REST API 키] > [클라이언트 시크릿] (REST API 키에 딸려 있다)
KAKAO_CLIENT_SECRET=
# 회원 탈퇴 시 연결 끊기(unlink)에 필요하다 — 카카오 로그인 서비스의 의무다.
KAKAO_ADMIN_KEY=
# 콘솔: [앱] > [플랫폼 키] > [REST API 키] > [리다이렉트 URI]
# 등록한 값과 문자 단위로 같아야 한다 (다르면 KOE006). 운영은 https 필수.
# 카카오는 Redirect URI에 커스텀 스킴(kcalairn://)을 등록할 수 없어, 서버가 콜백을 받고
# 앱으로 딥링크를 되돌려준다.
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback
APP_DEEPLINK_SCHEME=kcalairn
# KAKAO_TIMEOUT_SECONDS=5
# 운영은 콤마 구분 명시 목록만 허용된다 (localhost 정규식은 development에서만 적용).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# /api/predict 업로드 상한(MB). 초과 시 413.
PREDICT_MAX_UPLOAD_MB=10
# 민감정보(혈액형·질병·알러지) AES-256-GCM 키. base64(32바이트). 미설정 시 개발 기본키.
# 운영은 반드시 고유값 (미설정 시 APP_ENV=production 기동 실패):
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# HEALTH_ENCRYPTION_KEY=

# 이미지 인식은 Gemini 비전 단일 백엔드다(YOLO 제거). predict에 GEMINI_API_KEY 필요.
# 운영(APP_ENV=production)은 키가 없으면 기동 실패. 키는 로그·응답에 노출하지 않는다.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# GEMINI_TIMEOUT_MS=15000
# GEMINI_MAX_RETRIES=2


HF_TOKEN=
